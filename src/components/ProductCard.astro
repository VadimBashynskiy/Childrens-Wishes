---
import { resolveWixImageUrl } from "../utils/wix-image";

interface Props {
  product: {
    _id?: string;
    name?: string;
    slug?: string;
    media?: { main?: { image?: string } };
    actualPriceRange?: {
      minValue?: { formattedAmount?: string; amount?: string; currency?: string };
    };
    ribbon?: { name?: string };
  };
}

const { product } = Astro.props;

const imageUrl = resolveWixImageUrl(product.media?.main?.image, 600, 450);
const price = product.actualPriceRange?.minValue?.formattedAmount;
const href = `/products/${product.slug ?? product._id}`;
---

<a href={href} class="product-card card-hover">
  <article>
    <div class="card-image">
      {imageUrl ? (
        <img src={imageUrl} alt={product.name ?? "Product"} loading="lazy" />
      ) : (
        <div class="card-placeholder">🎁</div>
      )}
      {product.ribbon?.name && (
        <span class="card-ribbon">{product.ribbon.name}</span>
      )}
    </div>
    <div class="card-body">
      <h3 class="card-name">{product.name}</h3>
      {price && <p class="card-price">{price}</p>}
    </div>
  </article>
</a>

<style>
.product-card { text-decoration: none; display: block; }
article {
  border-radius: 24px;
  overflow: hidden;
  background: var(--surface);
  border: 1px solid var(--border);
}
.card-image {
  position: relative;
  aspect-ratio: 4/3;
  background: #F5F0E8;
  overflow: hidden;
}
.card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.product-card:hover img { transform: scale(1.05); }
.card-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3rem;
  opacity: 0.3;
}
.card-ribbon {
  position: absolute;
  top: 12px;
  left: 12px;
  padding: 4px 10px;
  border-radius: 999px;
  background: var(--gold);
  color: var(--ink);
  font-size: 11px;
  font-weight: 700;
}
.card-body { padding: 20px; }
.card-name {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.4;
  margin-bottom: 4px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-price { font-size: 15px; font-weight: 600; color: var(--peach); }
</style>
