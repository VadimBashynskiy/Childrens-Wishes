---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Children's Wishes — Make a Child's Dream Come True",
  description = "Grant a real child's wish through a donation. Every wish is personal. Every gift changes a life.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>✦</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,700;1,400;1,700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ══ Header ══ -->
  <header class="site-header" id="site-header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="Children's Wishes home">
        <span class="logo-mark" aria-hidden="true">✦</span>
        <span class="logo-text">Children's Wishes</span>
      </a>

      <nav class="nav" aria-label="Main navigation">
        <a href="/#how-it-works" class="nav-link">How it works</a>
        <a href="/#wishes"       class="nav-link">Wishes</a>
        <a href="/about"         class="nav-link">About</a>
      </nav>

      <a href="/#wishes" class="btn-yellow header-cta">Grant a Wish ✦</a>

      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span>
      </button>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- ══ Footer ══ -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo footer-logo">
          <span class="logo-mark">✦</span>
          <span class="logo-text">Children's Wishes</span>
        </a>
        <p class="footer-tagline">Every wish is real.<br/>Every gift changes a life.</p>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <p class="footer-col-title">Navigate</p>
          <a href="/#how-it-works">How it works</a>
          <a href="/#wishes">Active wishes</a>
          <a href="/#stats">Our impact</a>
          <a href="/about">About us</a>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">Contact</p>
          <a href="mailto:hello@childrenswishes.org">hello@childrenswishes.org</a>
          <p class="footer-note">We read every message.</p>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">Follow</p>
          <div class="footer-socials">
            <a href="#" class="social-link" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="#" class="social-link" aria-label="Twitter / X">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="#" class="social-link" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="container footer-bottom-inner">
        <p class="mono">© {new Date().getFullYear()} Children's Wishes. All rights reserved.</p>
        <p class="mono footer-love">Made with ♥ for children everywhere</p>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
/* ── Header ── */
.site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  background: rgba(255, 251, 245, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid transparent;
  transition: border-color 0.3s ease, background 0.3s ease;
}
.site-header.scrolled {
  border-bottom-color: var(--border);
  background: rgba(255, 251, 245, 0.96);
}
.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 68px;
  gap: 24px;
}
.logo {
  display: flex;
  align-items: center;
  gap: 9px;
  flex-shrink: 0;
}
.logo-mark {
  font-size: 20px;
  color: var(--yellow);
  line-height: 1;
}
.logo-text {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 17px;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.01em;
}
.nav {
  display: flex;
  align-items: center;
  gap: 32px;
}
.nav-link {
  font-size: 13px;
  font-weight: 600;
  color: var(--muted);
  letter-spacing: 0.01em;
  transition: color 0.2s;
  position: relative;
}
.nav-link::after {
  content: '';
  position: absolute;
  bottom: -3px; left: 0;
  width: 0; height: 1.5px;
  background: var(--ink);
  transition: width 0.25s ease;
}
.nav-link:hover { color: var(--ink); }
.nav-link:hover::after { width: 100%; }
.header-cta { font-size: 13px; padding: 11px 22px; flex-shrink: 0; }

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 4px;
}
.nav-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--ink);
  border-radius: 2px;
  transition: transform 0.2s, opacity 0.2s;
}

@media (max-width: 768px) {
  .nav, .header-cta { display: none; }
  .nav-toggle { display: flex; }
  .site-header.menu-open .nav {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 68px; left: 0; right: 0;
    background: var(--cream);
    padding: 24px 20px;
    border-bottom: 1px solid var(--border);
    gap: 20px;
  }
  .site-header.menu-open .header-cta {
    display: inline-flex;
    margin: 0 20px 24px;
  }
}

/* ── Footer ── */
.site-footer {
  background: var(--ink);
  color: rgba(255,251,245,0.55);
  padding-top: 72px;
}
.footer-inner {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 64px;
  padding-bottom: 64px;
}
@media (max-width: 768px) {
  .footer-inner { grid-template-columns: 1fr; gap: 40px; }
}
.footer-logo .logo-mark { color: var(--yellow); }
.footer-logo .logo-text { color: rgba(255,251,245,0.9); }
.footer-tagline {
  margin-top: 16px;
  font-size: 14px;
  line-height: 1.7;
  color: rgba(255,251,245,0.45);
}
.footer-links {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}
@media (max-width: 640px) {
  .footer-links { grid-template-columns: 1fr 1fr; }
}
.footer-col {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.footer-col-title {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,251,245,0.35);
  margin-bottom: 4px;
}
.footer-col a {
  font-size: 14px;
  color: rgba(255,251,245,0.6);
  transition: color 0.2s;
}
.footer-col a:hover { color: rgba(255,251,245,0.95); }
.footer-note { font-size: 12px; color: rgba(255,251,245,0.3); }
.footer-socials { display: flex; gap: 14px; }
.social-link {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 8px;
  color: rgba(255,251,245,0.5);
  border: 1px solid rgba(255,251,245,0.12);
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}
.social-link:hover {
  color: rgba(255,251,245,0.9);
  border-color: rgba(255,251,245,0.3);
  background: rgba(255,251,245,0.06);
}
.footer-bottom {
  border-top: 1px solid rgba(255,251,245,0.08);
  padding: 20px 0;
}
.footer-bottom-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.footer-love { color: rgba(255,251,245,0.3); }
</style>

<script>
  // Header scroll shadow
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  // Mobile menu toggle
  const toggle = document.querySelector('.nav-toggle');
  toggle?.addEventListener('click', () => {
    const open = header?.classList.toggle('menu-open');
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
